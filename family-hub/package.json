{
  "name": "family-hub",
  "version": "1.0.0",
  "description": "The Family Hub - A platform for family weekly updates",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node --watch server/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "better-sqlite3": "^11.0.0",
    "express": "^4.18.3",
    "express-session": "^1.18.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "resend": "^3.2.0",
    "sharp": "^0.33.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
